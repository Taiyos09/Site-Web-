generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = "mysql://root:@localhost:3306/auberge_saint_aubin"
}

model admins {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   @db.Text
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model blocked_dates {
  id        Int       @id @default(autoincrement())
  date      DateTime
  reason    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  room_slug String?
  reservation_id Int?
  from_date DateTime?
  to_date   DateTime?
}

model hotel_settings {
  id            Int      @id @default(autoincrement())
  key           String   @unique
  value         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lit_parapluie Float    @default(5)
}

model reservation_rooms {
  id            Int          @id @default(autoincrement())
  reservationId Int
  roomId        Int
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  reservation   reservations @relation(fields: [reservationId], references: [id])
  room          rooms        @relation(fields: [roomId], references: [id])

  @@index([reservationId], map: "reservation_rooms_reservationId_fkey")
  @@index([roomId], map: "reservation_rooms_roomId_fkey")
}

model reservations {
  id              Int                 @id @default(autoincrement())
  name            String
  email           String
  phone           String
  arrival         DateTime
  departure       DateTime
  adults          Int
  children        Int                 @default(0)
  babies          Int                 @default(0)
  litParapluie    Boolean             @default(false)
  total           Float
  subtotal         Float?    @default(0)
  discountType     String?   
  discountValue    Float?    @default(0)
  discountReason   String?
  depositRequested Boolean    @default(false)
  discountAmount   Float?    @default(0)
  depositPaid      Boolean    @default(false)
  depositPaidAt    DateTime?
  status          String              @default("pending")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  dinner          Boolean             @default(false)
  lunch           Boolean             @default(false)
  pets            Boolean             @default(false)
  breakfast       Boolean             @default(false)
  depositAmount   Float               @default(0)
  rooms           reservation_rooms[]
}

model events {
  id          Int      @id @default(autoincrement())
  title       String
  date        DateTime
  description String
  image       String
  showWarning Boolean @default(false)
  gallery     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  slug        String   @unique
}

model rooms {
  id              Int                 @id @default(autoincrement())
  slug            String              @unique
  size            String
  nameFr String?
  nameEn String?
  nameNl String?

  descriptionFr String? @db.Text
  descriptionEn String? @db.Text
  descriptionNl String? @db.Text
  images          String
  priceOnePerson  Int
  priceTwoPeople  Int
  priceDoubleRoom Int
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  capacity        Int                 @default(2)
  reservations    reservation_rooms[]
}

model tourism_places {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String?  @unique
  description String?  @db.Text
  image       String?
  address     String?
  maps_url    String?
  website     String?
  category    String?
  featured    Boolean  @default(false)
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  travel_time String?
}

model memories {
  id        Int      @id @default(autoincrement())
  title     String
  images    String   @db.LongText
  featured  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
